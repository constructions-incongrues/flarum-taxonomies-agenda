# Copie ce fichier en .env et ajuste si besoin.
# docker-compose le lit automatiquement.

# --- Base de données ---
DB_ROOT_PASSWORD=root
DB_NAME=flarum
DB_USER=flarum
DB_PASSWORD=flarum
# Port exposé sur l'hôte pour la DB (au cas où tu veux te connecter avec un client SQL).
# 3307 par défaut pour ne pas entrer en conflit avec un MySQL/MariaDB local sur 3306.
DB_PORT=3307

# --- Flarum ---
# URL publique. Si tu veux accéder depuis ton navigateur local, http://localhost:<FLARUM_PORT> suffit.
FLARUM_URL=http://localhost:8888
FLARUM_PORT=8888
FLARUM_TITLE=Musiques Incongrues (dev)

# Compte admin créé au premier install. À changer si tu crains que ça traîne dans un dump.
FLARUM_ADMIN_USER=admin
FLARUM_ADMIN_PASSWORD=admin1234
FLARUM_ADMIN_EMAIL=admin@example.com
